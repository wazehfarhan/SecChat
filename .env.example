# ════════════════════════════════════════════════════════════
# VanishChat — Environment Variables Configuration
# ════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ────────────────────────────────────────────────────────────
# Server Configuration
# ────────────────────────────────────────────────────────────

# Port the Express server listens on
PORT=3000

# Environment: 'development' | 'production' | 'test'
NODE_ENV=development

# For production HTTPS, enable TLS (uncomment in server.js)
# SSL_KEY_PATH=/etc/ssl/private/key.pem
# SSL_CERT_PATH=/etc/ssl/certs/cert.pem

# CORS origin for Socket.IO connections
# In production, replace * with your actual domain
CORS_ORIGIN=*

# ────────────────────────────────────────────────────────────
# Database Configuration
# ────────────────────────────────────────────────────────────

# MySQL host (use 127.0.0.1 for local, not 'localhost')
DB_HOST=127.0.0.1

# MySQL port
DB_PORT=3306

# MySQL username
DB_USER=root

# MySQL password
DB_PASSWORD=

# Database name
DB_NAME=vanishchat

# Connection pool settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# Connection retry settings (for startup validation)
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY_MS=2000

# ────────────────────────────────────────────────────────────
# Security Configuration
# ────────────────────────────────────────────────────────────

# Session secret for signed cookies (if session-based auth added later)
SESSION_SECRET=your-super-secret-key-change-this-in-production

# Room password hashing rounds (bcrypt cost factor)
BCRYPT_ROUNDS=10

# ────────────────────────────────────────────────────────────
# Rate Limiting Configuration
# ────────────────────────────────────────────────────────────

# Room creation rate limit window (milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Max rooms allowed per window per IP
RATE_LIMIT_MAX=10

# ────────────────────────────────────────────────────────────
# Cleanup Service Configuration
# ────────────────────────────────────────────────────────────

# How often to sweep for expired rooms (milliseconds)
CLEANUP_INTERVAL_MS=60000

# ────────────────────────────────────────────────────────────
# Feature Flags (Optional)
# ────────────────────────────────────────────────────────────

# Enable room password protection
FEATURE_ROOM_PASSWORD=true

# Enable typing indicators
FEATURE_TYPING_INDICATORS=true

# Enable read receipts
FEATURE_READ_RECEIPTS=true

# ────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────

# Log level: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info

# ════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS:
# ════════════════════════════════════════════════════════════
# 1. Copy this file: cp .env.example .env
# 2. Update values to match your local/production environment
# 3. For development: mostly defaults work fine
# 4. For production: set NODE_ENV=production, enable HTTPS, 
#    update CORS_ORIGIN, use strong SESSION_SECRET
# 5. Never commit .env — it contains secrets!
# ════════════════════════════════════════════════════════════
